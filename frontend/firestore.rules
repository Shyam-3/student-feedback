rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTceFaculty() {
      return isSignedIn()
        && ('email' in request.auth.token)
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@tce\\.edu$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isTceFaculty()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'hod';
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isTceFaculty()
        && request.auth.uid == userId
        && request.resource.data.role == 'faculty';
      allow update: if isAdmin()
        || (request.auth.uid == userId
          && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin()
        || (isTceFaculty()
          && (
            reportId.matches(request.auth.uid + '_.*')
            || isOwner(resource.data.userId)
          ));

      allow create: if isTceFaculty()
        && isOwner(request.resource.data.userId)
        && ('userId' in request.resource.data)
        && (request.resource.data.userId is string)
        && reportId.matches(request.auth.uid + '_.*');

      allow update, delete: if isAdmin()
        || (isTceFaculty() && isOwner(resource.data.userId));
    }
  }
}
